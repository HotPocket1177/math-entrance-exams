# ════════════════════════════════════════════════════════════════
# .env.example — dokumentace proměnných prostředí
# Zkopíruj do .env a vyplň skutečné hodnoty.
# NIKDY necommituj .env do gitu!
# ════════════════════════════════════════════════════════════════

# ── Supabase (veřejné — bezpečné pro frontend / config.js) ──────
# Najdeš v: supabase.com → tvůj projekt → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── OpenAI (SECRET — pouze do Supabase secrets, NIKDY na frontend) ──
# Nastav přes: supabase secrets set OPENAI_API_KEY=sk-...
# Tento klíč NESMÍ být nikdy v config.js ani v žádném JS souboru!
OPENAI_API_KEY=sk-...

# ── CORS (volitelné — Edge Function) ────────────────────────────
# Doména odkud frontend volá Edge Function.
# "*" = povolení všech (vhodné pro vývoj, v produkci upřesni)
# Nastav přes: supabase secrets set ALLOWED_ORIGIN=https://tvoje-domena.cz
ALLOWED_ORIGIN=https://hotpocket1177.github.io

# ── Lokální vývoj (nepovinné) ───────────────────────────────────
# Pokud chceš testovat bez Supabase, nastav useEdgeFunction: false v config.js
# a použij přímý OpenAI klíč v localStorage prohlížeče.
